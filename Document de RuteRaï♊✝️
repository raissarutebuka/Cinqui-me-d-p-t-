ell_type":"code","source":["\n","# ============================================================\n","# 5. MODÈLE 2 : CLUSTERING (K-MEANS)\n","# ============================================================\n","\n","print(\"\\n\" + \"=\" * 70)\n","print(\"5. MODÈLE 2 : CLUSTERING (K-MEANS)\")\n","print(\"=\" * 70)\n","\n","# Recherche du nombre optimal de clusters (méthode du coude + silhouette)\n","inertias = []\n","silhouettes = []\n","K_range = range(2, 11)\n","\n","for k in K_range:\n","    kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)\n","    kmeans.fit(X_train_scaled)\n","    inertias.append(kmeans.inertia_)\n","    silhouettes.append(silhouette_score(X_train_scaled, kmeans.labels_))\n","\n","# Choix du meilleur k\n","best_k = list(K_range)[np.argmax(silhouettes)]\n","print(f\"\\n📊 Meilleur nombre de clusters (silhouette) : k = {best_k}\")\n","print(f\"   Score de silhouette maximal : {max(silhouettes):.4f}\")\n","\n","# Modèle final\n","kmeans_final = KMeans(n_clusters=3, random_state=42, n_init=10)  # 3 clusters = 3 niveaux de risque\n","clusters_train = kmeans_final.fit_predict(X_train_scaled)\n","clusters_test = kmeans_final.predict(X_test_scaled)\n","\n","print(f\"\\n📋 Distribution des clusters (train) :\")\n","unique, counts = np.unique(clusters_train, return_counts=True)\n","for u, c in zip(unique, counts):\n","    print(f\"   Cluster {u} : {c} échantillons ({c/len(clusters_train)*100:.1f}%)\")\n","\n","# Analyse des clusters vs classes réelles\n","print(f\"\\n🔗 Comparaison Clusters vs Niveaux de Risque réels :\")\n","comparison_df = pd.DataFrame({\n","    'Cluster': clusters_train,\n","    'Risk_Level': [le.classes_[i] for i in y_train]\n","})\n","crosstab = pd.crosstab(comparison_df['Cluster'], comparison_df['Risk_Level'], margins=True)\n","print(crosstab)\n","\n","# PCA pour visualisation\n","pca = PCA(n_components=2)\n","X_train_pca = pca.fit_transform(X_train_scaled)\n","X_test_pca = pca.transform(X_test_scaled)\n","\n","print(f\"\\n📉 Variance expliquée par PCA : {pca.explained_variance_ratio_}\")\n","print(f\"   Variance totale expliquée : {sum(pca.explained_variance_ratio_):.2%}\")\n","\n","# Visualisation\n","fig, axes = plt.subplots(2, 2, figsize=(16, 14))\n","\n","# Méthode du coude\n","ax1 = axes[0, 0]\n","ax1.plot(K_range, inertias, 'bo-', linewidth=2, markersize=8)\n","ax1.set_xlabel('Nombre de Clusters (k)')\n","ax1.set_ylabel('Inertie (WCSS)')\n","ax1.set_title('Méthode du Coude', fontsize=14, fontweight='bold')\n","ax1.axvline(x=3, color='red', linestyle='--', label='k=3 (risques)')\n","ax1.legend()\n","ax1.grid(True, alpha=0.3)\n","\n","# Score de silhouette\n","ax2 = axes[0, 1]\n","ax2.plot(K_range, silhouettes, 'go-', linewidth=2, markersize=8)\n","ax2.set_xlabel('Nombre de Clusters (k)')\n","ax2.set_ylabel('Score de Silhouette')\n","ax2.set_title('Score de Silhouette', fontsize=14, fontweight='bold')\n","ax2.axvline(x=best_k, color='red', linestyle='--', label=f'k={best_k} (optimal)')\n","ax2.legend()\n","ax2.grid(True, alpha=0.3)\n","\n","# Clusters en PCA (données d'entraînement)\n","ax3 = axes[1, 0]\n","scatter = ax3.scatter(X_train_pca[:, 0], X_train_pca[:, 1],\n","                      c=clusters_train, cmap='viridis', s=50, alpha=0.7, edgecolors='black')\n","ax3.set_xlabel(f'PC1 ({pca.explained_variance_ratio_[0]:.1%} variance)')\n","ax3.set_ylabel(f'PC2 ({pca.explained_variance_ratio_[1]:.1%} variance)')\n","ax3.set_title('Clusters K-Means (PCA)', fontsize=14, fontweight='bold')\n","legend1 = ax3.legend(*scatter.legend_elements(), title=\"Clusters\", loc='upper right')\n","ax3.add_artist(legend1)\n","\n","# Comparaison avec les vraies classes\n","ax4 = axes[1, 1]\n","colors_true = ['#e74c3c' if r == 0 else '#2ecc71' if r == 1 else '#f39c12' for r in y_train]\n","scatter2 = ax4.scatter(X_train_pca[:, 0], X_train_pca[:, 1],\n","                       c=colors_true, s=50, alpha=0.7, edgecolors='black')\n","ax4.set_xlabel(f'PC1 ({pca.explained_variance_ratio_[0]:.1%} variance)')\n","ax4.set_ylabel(f'PC2 ({pca.explained_variance_ratio_[1]:.1%} variance)')\n","ax4.set_title('Niveaux de Risque Réels (PCA)', fontsize=14, fontweight='bold')\n","\n","# Légende manuelle pour les vraies classes\n","from matplotlib.patches import Patch\n","legend_elements = [Patch(facecolor='#e74c3c', label='High'),\n","                   Patch(facecolor='#2ecc71', label='Low'),\n","                   Patch(facecolor='#f39c12', label='Medium')]\n","ax4.legend(handles=legend_elements, title=\"Risk Level\", loc='upper right')\n","\n","plt.tight_layout()\n","plt.savefig('/mnt/agents/output/3_Clustering_KMeans.png', dpi=300, bbox_inches='tight')\n","plt.show()\n","\n","print(\"\\n✅ Clustering K-Means terminé. Graphique sauvegardé.\")"],"metadata":{"id":"klEA4u2NLln_","colab":{"base_uri":"https://localhost:8080/","height":1000},"executionInfo":{"status":"error","timestamp":1781861760010,"user_tz":-120,"elapsed":6021,"user":{"displayName":"Christophe Ushindi Murhabazi","userId":"05218484845599033338"}},"outputId":"0436f31a-dc1c-423c-eb55-ca0471d5e6da"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\n","======================================================================\n","5. MODÈLE 2 : CLUSTERING (K-MEANS)\n","======================================================================\n","\n","📊 Meilleur nombre de clusters (silhouette) : k = 2\n","   Score de silhouette maximal : 0.0436\n","\n","📋 Distribution des clusters (train) :\n","   Cluster 0 : 122 échantillons (31.4%)\n","   Cluster 1 : 150 échantillons (38.6%)\n","   Cluster 2 : 117 échantillons (30.1%)\n","\n","🔗 Comparaison Clusters vs Niveaux de Risque réels :\n","Risk_Level  High  Low  Medium  All\n","Cluster                           \n","0             60    4      58  122\n","1             30   14     106  150\n","2              8   26      83  117\n","All           98   44     247  389\n","\n","📉 Variance expliquée par PCA : [0.0694342  0.06778871]\n","   Variance totale ex